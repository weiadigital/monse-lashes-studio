---
/**
 * T3 — Precio Al Frente
 * Intención: "El cliente decide por precio — dárselo de inmediato"
 * Sectores default: nail salon (F≤3), barbería moderna básica, taquería
 * Estructura: Hero compacto con badge promo → Servicios lista INMEDIATO
 *             → Testimonios → Mapa + horario → Footer
 *
 * INSTRUCCIONES PARA SOF.IA:
 * 1. El hero es COMPACTO (55-65vh). El cliente debe ver precios
 *    sin scroll en mobile. Esto es la regla #1 de este template.
 * 2. ServiciosList va INMEDIATAMENTE después del hero, sin secciones intermedias.
 * 3. Badge en HeroMinimal: si hay promo activa del campo "especial" del briefing,
 *    mostrarla. Si no, poner el servicio más popular con precio.
 * 4. Si el negocio NO tiene dirección física (servicio a domicilio),
 *    omitir la sección de Mapa y Horario completa.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import NavbarFlotante from '../components/NavbarFlotante.astro';
import HeroMinimal from '../components/HeroMinimal.astro';
import ServiciosList from '../components/ServiciosList.astro';
import SocialProofResenas from '../components/SocialProofResenas.astro';
import ContactoWhatsApp from '../components/ContactoWhatsApp.astro';
import Footer from '../components/Footer.astro';
import GoogleTagManager from '../components/GoogleTagManager.astro';

// ─── DATOS DEL CLIENTE ────────────────────────────────────────────────────────

const negocio = {
  nombre:      '[NOMBRE_NEGOCIO]',
  descripcion: '[DESCRIPCION_1_ORACION]',
  telefono:    '[10_DIGITOS_SIN_PREFIJO]',
  whatsapp:    '[10_DIGITOS_SIN_PREFIJO]',
  direccion:   '[DIRECCION_COMPLETA]',      // null si es a domicilio
  ciudad:      '[CIUDAD_ALCALDIA]',
  cp:          '[CODIGO_POSTAL]',
  horario:     '[HORARIO_TEXTO]',
  tipoSchema:  '[TIPO_SCHEMA]',
  email:       undefined,
  tieneDireccion: true, // false si es a domicilio
  redes: [],
};

const seo = {
  titulo:      '[TITULO_SEO_50_CHARS]',
  descripcion: '[META_DESC_155_CHARS]',
  canonicalUrl: 'https://[DOMINIO].weia.digital',
  ogImagen:    'https://[DOMINIO].weia.digital/og-default.jpg',
};

const tokens = {
  tokenPrimary:  '[TOKEN_PRIMARY_OKLCH]',
  tokenSurface:  '[TOKEN_SURFACE_OKLCH]',
  tokenText:     '[TOKEN_TEXT_OKLCH]',
  tokenCta:      '[TOKEN_CTA_OKLCH]',
};

// Perfil de movimiento — derivado de Energía calculada del briefing
// E 1-2 → 'subtle' | E 3-4 → 'fluid' | E 5 → 'expressive'
const motionProfile = '[MOTION_PROFILE]' as 'subtle' | 'fluid' | 'expressive';

const fuentes = {
  heading: '[FUENTE_HEADING]',
  body:    'Inter',
};

// ─── CONTENIDO ────────────────────────────────────────────────────────────────

const navLinks = [
  { texto: 'Precios',   href: '#servicios' },
  { texto: 'Reseñas',   href: '#resenas' },
  { texto: 'Ubicación', href: '#contacto' },
  // T3 es compacto — pocos links
];

const hero = {
  titulo:    '[HEADLINE_DIRECTO_CON_PRECIO_O_LUGAR]',
  // ej. "Uñas perfectas desde $250 en Tláhuac"
  // ej. "El corte que buscas. $80 en Iztapalapa"
  subtitulo: '[SUBTITULO_REFUERZO_OPCIONAL]',
  badge:     '[PROMO_O_SERVICIO_POPULAR]',
  // Si hay promo activa: "2x1 gelish los miércoles"
  // Si no: "Uñas acrílicas desde $250"
  ctaTexto:  '[TEXTO_CTA]',
  ctaUrl:    `https://api.whatsapp.com/send?phone=521${negocio.whatsapp}&text=${encodeURIComponent('Hola, quiero agendar')}`,
  ctaSecundarioTexto: 'Ver precios',
  ctaSecundarioUrl:   '#servicios',
  // Stats opcionales — solo si hay datos reales
  // stats: [
  //   { numero: '300+', label: 'clientas satisfechas' },
  //   { numero: '5★',   label: 'en Google' },
  // ],
};

// LISTA COMPLETA de servicios con precios — este es el corazón del template
const servicios = [
  { nombre: '[SERVICIO_1]', precio: 0, descripcion: '[DESC_BREVE_OPCIONAL]' },
  { nombre: '[SERVICIO_2]', precio: 0 },
  { nombre: '[SERVICIO_3]', precio: 0 },
  { nombre: '[SERVICIO_4]', precio: 0 },
  // Agregar TODOS los servicios del briefing
];

const resenas: { nombre: string; texto: string; estrellas: number }[] = [
  // SOLO reales
  // { nombre: '[NOMBRE]', texto: '[TEXTO]', estrellas: 5 },
];

// Google Maps embed — solo si tieneDireccion = true
// CÓMO OBTENER LA URL (el cliente o tú la consiguen en 1 minuto):
//   1. Ir a maps.google.com y buscar el negocio por nombre o dirección
//   2. Clic en "Compartir" (ícono de compartir) → pestaña "Insertar un mapa"
//   3. Copiar SOLO el valor del atributo src="..." del código iframe que aparece
//      Ejemplo: "https://www.google.com/maps/embed?pb=!1m18..."
//   4. Pegar esa URL aquí abajo
// Si el cliente es a domicilio (tieneDireccion = false) → dejar como string vacío
const mapsEmbed = '[URL_SRC_DEL_IFRAME — ver instrucciones arriba]';

const gtmId = '[GTM-XXXXXXX]';
---

{gtmId && <GoogleTagManager gtmId={gtmId} />}

<BaseLayout
  titulo={seo.titulo}
  descripcion={seo.descripcion}
  canonicalUrl={seo.canonicalUrl}
  ogImagen={seo.ogImagen}
  schema={{
    nombre:      negocio.nombre,
    descripcion: negocio.descripcion,
    telefono:    negocio.telefono,
    direccion:   negocio.direccion,
    ciudad:      negocio.ciudad,
    cp:          negocio.cp,
    horario:     negocio.horario,
    tipoNegocio: negocio.tipoSchema,
  }}
  telefono={negocio.whatsapp}
  mensajeWa={`Hola, vi tu página y quiero agendar`}
  {...tokens}
  motionProfile={motionProfile}
  fuenteHeading={fuentes.heading}
  fuenteBody={fuentes.body}
>
  {/* ── NAVBAR flotante (modo claro) ── */}
  <NavbarFlotante
    nombre={negocio.nombre}
    links={navLinks}
    ctaTexto={hero.ctaTexto}
    ctaUrl={hero.ctaUrl}
    modo="claro"
  />

  {/* ── SECCIÓN 1: Hero compacto — precio en badge ── */}
  <HeroMinimal
    titulo={hero.titulo}
    subtitulo={hero.subtitulo}
    badge={hero.badge}
    ctaTexto={hero.ctaTexto}
    ctaUrl={hero.ctaUrl}
    ctaSecundarioTexto={hero.ctaSecundarioTexto}
    ctaSecundarioUrl={hero.ctaSecundarioUrl}
  />

  {/* ── SECCIÓN 2: PRECIOS — INMEDIATAMENTE después del hero ──
      Sin break, sin intermediario. El cliente los ve sin scroll en mobile. */}
  <ServiciosList
    servicios={servicios}
    titulo="Precios"
  />

  {/* ── SECCIÓN 3: Testimonios (solo si hay reales) ── */}
  {resenas.length > 0 && (
    <SocialProofResenas
      reseñas={resenas}
      titulo="Clientes satisfechos"
    />
  )}

  {/* ── SECCIÓN 4: Ubicación y horario (solo si tiene dirección física) ── */}
  {negocio.tieneDireccion && (
    <ContactoWhatsApp
      telefono={negocio.whatsapp}
      direccion={negocio.direccion}
      horario={negocio.horario}
      titulo="¿Dónde estamos?"
      googleMapsEmbed={mapsEmbed}
    />
  )}

  {/* ── SECCIÓN 5: Footer ── */}
  <Footer
    negocio={negocio.nombre}
    direccion={negocio.tieneDireccion ? negocio.direccion : negocio.ciudad}
    telefono={negocio.telefono}
    redes={negocio.redes}
  />
</BaseLayout>
