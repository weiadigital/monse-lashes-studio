---
interface Red {
  nombre: string;
  url: string;
  icono?: string;
}

interface Props {
  negocio: string;
  direccion: string;
  telefono: string;
  email?: string;
  redes?: Red[];
  avisoUrl?: string;
  copyright?: string;
}

const {
  negocio,
  direccion,
  telefono,
  email,
  redes = [],
  avisoUrl = '/aviso-de-privacidad',
  copyright,
} = Astro.props;

const year = new Date().getFullYear();
const phoneClean = telefono.replace(/\D/g, '');
---

<footer class="footer" itemscope itemtype="https://schema.org/LocalBusiness">
  <div class="footer__inner">
    <div class="footer__brand">
      <span class="footer__name" itemprop="name">{negocio}</span>
      <address class="footer__nap" itemprop="address" itemscope itemtype="https://schema.org/PostalAddress">
        <span itemprop="streetAddress">{direccion}</span>
      </address>
      <a
        href={`tel:+52${phoneClean}`}
        class="footer__tel"
        itemprop="telephone"
        aria-label={`Llamar al ${telefono}`}
      >
        {telefono}
      </a>
      {email && (
        <a href={`mailto:${email}`} class="footer__email" itemprop="email">
          {email}
        </a>
      )}
    </div>

    {redes.length > 0 && (
      <nav class="footer__redes" aria-label="Redes sociales">
        <ul role="list">
          {redes.map((r) => {
            const nombre = r.nombre.toLowerCase();
            return (
              <li>
                <a
                  href={r.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={r.nombre}
                  class={`footer__red-link footer__red-link--${nombre.replace(/[^a-z]/g, '')}`}
                >
                  {/* SVGs oficiales según Brand Guidelines de cada plataforma */}
                  {nombre.includes('instagram') && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                      <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 3.252.148 4.771 1.691 4.919 4.919.049 1.265.064 1.645.064 4.849 0 3.205-.015 3.585-.074 4.85-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.072-4.85.072-3.204 0-3.584-.014-4.849-.072-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.072-1.644-.072-4.849 0-3.204.013-3.583.072-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.071 4.849-.071zM12 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                    </svg>
                  )}
                  {nombre.includes('facebook') && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                  )}
                  {nombre.includes('tiktok') && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                      <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
                    </svg>
                  )}
                  {(nombre.includes('twitter') || nombre.includes(' x ') || nombre === 'x') && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.742l7.735-8.835L1.254 2.25H8.08l4.26 5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                  )}
                  {nombre.includes('youtube') && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                      <path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/>
                    </svg>
                  )}
                  {nombre.includes('linkedin') && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                  )}
                  {/* Fallback para redes no mapeadas */}
                  {!nombre.includes('instagram') && !nombre.includes('facebook') && !nombre.includes('tiktok') && !nombre.includes('twitter') && nombre !== 'x' && !nombre.includes(' x ') && !nombre.includes('youtube') && !nombre.includes('linkedin') && (
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <circle cx="12" cy="12" r="10"/>
                      <path d="M12 8v4m0 4h.01"/>
                    </svg>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>
    )}
  </div>

  <div class="footer__legal">
    <p class="footer__copy">
      © {year} {negocio}. {copyright ?? 'Todos los derechos reservados.'}
    </p>
    <nav aria-label="Links legales">
      <ul role="list" class="footer__legal-links">
        <li>
          <a href={avisoUrl}>Aviso de Privacidad</a>
        </li>
      </ul>
    </nav>
  </div>
</footer>

<style>
  .footer {
    background-color: oklch(13% 0.02 270);
    color: oklch(80% 0.01 230);
    padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 5vw, 3rem) clamp(1.5rem, 4vw, 2rem);
  }

  .footer__inner {
    max-width: 72rem;
    margin-inline: auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 3rem;
    flex-wrap: wrap;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid oklch(100% 0 0 / 0.08);
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__name {
    font-size: 1.25rem;
    font-weight: 800;
    color: oklch(97% 0.005 230);
    letter-spacing: -0.01em;
  }

  .footer__nap {
    font-style: normal;
    font-size: 0.875rem;
    line-height: 1.6;
    max-width: 36ch;
    opacity: 0.75;
  }

  .footer__tel,
  .footer__email {
    font-size: 0.9375rem;
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s;
    width: fit-content;
  }

  .footer__tel:hover,
  .footer__email:hover {
    opacity: 0.8;
  }

  .footer__redes ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer__red-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3rem;      /* 48px — tap target mínimo Google/WCAG */
    height: 3rem;
    border: 1px solid oklch(100% 0 0 / 0.15);
    border-radius: 0.5rem;
    color: oklch(85% 0.01 230);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s, background-color 0.2s;
  }

  .footer__red-link:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background-color: oklch(from var(--color-primary) l c h / 0.08);
  }

  /* Focus visible — WCAG 2.2 AA, navegación por teclado */
  .footer__red-link:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 3px;
    border-radius: 0.5rem;
  }

  /* Colores de marca oficiales en hover — Brand Guidelines de cada plataforma */
  .footer__red-link--instagram:hover  { border-color: #E4405F; color: #E4405F; background-color: oklch(56% 0.22 5 / 0.1); }
  .footer__red-link--facebook:hover   { border-color: #1877F2; color: #1877F2; background-color: oklch(53% 0.22 255 / 0.1); }
  .footer__red-link--tiktok:hover     { border-color: #fff;    color: #fff;    background-color: oklch(0% 0 0 / 0.4); }
  .footer__red-link--x:hover,
  .footer__red-link--twitter:hover    { border-color: #fff;    color: #fff;    background-color: oklch(0% 0 0 / 0.4); }
  .footer__red-link--youtube:hover    { border-color: #FF0000; color: #FF0000; background-color: oklch(50% 0.3 27 / 0.1); }
  .footer__red-link--linkedin:hover   { border-color: #0A66C2; color: #0A66C2; background-color: oklch(46% 0.18 243 / 0.1); }

  .footer__legal {
    max-width: 72rem;
    margin-inline: auto;
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer__copy {
    font-size: 0.8125rem;
    margin: 0;
    opacity: 0.55;
  }

  .footer__legal-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.5rem;
  }

  .footer__legal-links a {
    font-size: 0.8125rem;
    color: oklch(70% 0.01 230);
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer__legal-links a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .footer__legal {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
