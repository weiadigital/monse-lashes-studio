---
/**
 * MapaProminente.astro — Mapa + info de ubicación con WhatsApp
 * El mapa ocupa 60% del espacio — la ubicación es el argumento principal.
 * Zero JS. WCAG 2.2 AA.
 * Uso: T5-LocalUrgente. Negocios con ubicación física como diferenciador.
 *
 * INSTRUCCIÓN PARA MIXTLI:
 * embedUrl es OBLIGATORIO en este componente.
 * Cómo obtenerla (el cliente o tú en 1 minuto):
 *   1. Ir a maps.google.com y buscar el negocio
 *   2. Clic en "Compartir" → pestaña "Insertar un mapa"
 *   3. Copiar SOLO el valor del atributo src="..." del iframe
 */

interface Props {
  embedUrl: string;          // URL src del iframe de Google Maps
  direccion: string;
  horario: string;           // texto breve del horario
  whatsapp: string;          // 10 dígitos sin prefijo
  titulo?: string;
  mensajeWa?: string;
}

const {
  embedUrl,
  direccion,
  horario,
  whatsapp,
  titulo = '¿Dónde estamos?',
  mensajeWa = 'Hola, quiero hacer un pedido',
} = Astro.props;

const phoneClean = whatsapp.replace(/\D/g, '');
const waUrl = `https://api.whatsapp.com/send?phone=521${phoneClean}&text=${encodeURIComponent(mensajeWa)}`;
---

<section class="mapa-prominente" aria-label="Ubicación y contacto">
  <div class="mapa-prominente__inner">

    <div class="mapa-prominente__info">
      <h2 class="mapa-prominente__titulo">{titulo}</h2>

      <address class="mapa-prominente__dir">{direccion}</address>

      <p class="mapa-prominente__horario-label">Horario</p>
      <p class="mapa-prominente__horario">{horario}</p>

      <a
        href={waUrl}
        class="mapa-prominente__wa-btn"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Escribir por WhatsApp"
      >
        {/* SVG oficial WhatsApp — Brand Kit de Meta/WhatsApp */}
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Escríbenos
      </a>
    </div>

    <div class="mapa-prominente__mapa-wrap">
      <iframe
        src={embedUrl}
        width="800"
        height="450"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`Mapa de ubicación: ${direccion}`}
      ></iframe>
    </div>

  </div>
</section>

<style>
  .mapa-prominente {
    padding: clamp(4rem, 10vw, 6rem) clamp(1.25rem, 5vw, 3rem);
    background-color: oklch(from var(--color-surface) calc(l - 0.02) c h);
  }

  .mapa-prominente__inner {
    max-width: 72rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 1.6fr; /* info 40% · mapa 60% */
    gap: 4rem;
    align-items: center;
  }

  .mapa-prominente__titulo {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    color: var(--color-text);
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
    font-family: var(--font-heading, inherit);
  }

  .mapa-prominente__dir {
    font-style: normal;
    font-size: 0.9375rem;
    color: oklch(from var(--color-text) l c h / 0.75);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .mapa-prominente__horario-label {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: oklch(from var(--color-text) l c h / 0.5);
    margin: 0 0 0.25rem;
  }

  .mapa-prominente__horario {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 1.75rem;
  }

  .mapa-prominente__wa-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: #25D366;
    color: #fff;
    font-weight: 700;
    font-size: 0.9375rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.15s;
  }

  .mapa-prominente__wa-btn:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .mapa-prominente__mapa-wrap {
    border-radius: 1rem;
    overflow: hidden;
    aspect-ratio: 16/10;
    box-shadow: 0 8px 32px oklch(0% 0 0 / 0.12);
  }

  .mapa-prominente__mapa-wrap iframe {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (max-width: 768px) {
    .mapa-prominente__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .mapa-prominente__mapa-wrap {
      aspect-ratio: 16/9;
    }
  }
</style>
