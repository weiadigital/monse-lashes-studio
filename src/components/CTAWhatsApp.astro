---
/**
 * CTAWhatsApp.astro — Botón flotante WhatsApp con UTM tracking
 * Posición: fixed bottom-right
 * WCAG 2.2 AA: aria-label descriptivo, focus visible, motion-safe
 * Zero JS salvo el atributo href dinámico (construido en frontmatter)
 */

interface Props {
  telefono: string;
  mensaje?: string;
  utmSource?: string;
  utmMedium?: string;
  utmCampaign?: string;
  label?: string;
  mostrarTexto?: boolean;
}

const {
  telefono,
  mensaje = 'Hola, vi tu página y quiero más información',
  utmSource = 'website',
  utmMedium = 'cta_flotante',
  utmCampaign = 'whatsapp',
  label = 'Escríbenos por WhatsApp',
  mostrarTexto = true,
} = Astro.props;

const phoneClean = telefono.replace(/\D/g, '');
const textoConRef = `${mensaje} (ref:${utmSource}_${utmCampaign})`;
const waUrl = `https://api.whatsapp.com/send?phone=521${phoneClean}&text=${encodeURIComponent(textoConRef)}`;
---

<a
  href={waUrl}
  target="_blank"
  rel="noopener noreferrer"
  class={`cta-wa-flotante${mostrarTexto ? ' cta-wa-flotante--con-texto' : ''}`}
  aria-label={label}
  data-utm-source={utmSource}
  data-utm-medium={utmMedium}
  data-utm-campaign={utmCampaign}
>
  <span class="cta-wa-flotante__icon" aria-hidden="true">
    {/* SVG oficial WhatsApp — Brand Kit de Meta/WhatsApp */}
    <svg
      width="28"
      height="28"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
    </svg>
  </span>
  {mostrarTexto && (
    <span class="cta-wa-flotante__texto">WhatsApp</span>
  )}
</a>

<style>
  .cta-wa-flotante {
    position: fixed;
    bottom: clamp(1.25rem, 4vw, 2rem);
    right: clamp(1.25rem, 4vw, 2rem);
    z-index: 9000;

    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;

    /* Círculo perfecto en modo icono */
    width: 3.25rem;
    height: 3.25rem;
    padding: 0;

    background-color: #25D366;
    color: #fff;
    border-radius: 50%;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9375rem;
    line-height: 1;

    box-shadow:
      0 4px 16px oklch(0% 0 0 / 0.22),
      0 1px 4px oklch(0% 0 0 / 0.14);

    transition:
      transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.2s ease,
      background-color 0.15s ease;
  }

  /* Con texto: pill redondeada, no círculo */
  .cta-wa-flotante--con-texto {
    width: auto;
    height: auto;
    padding: 0.875rem 1.375rem 0.875rem 1rem;
    border-radius: 3rem;
  }

  .cta-wa-flotante:hover {
    background-color: #1ebe5d;
    transform: translateY(-3px) scale(1.04);
    box-shadow:
      0 8px 28px oklch(0% 0 0 / 0.22),
      0 2px 8px oklch(0% 0 0 / 0.14);
  }

  .cta-wa-flotante:active {
    transform: translateY(-1px) scale(1.01);
  }

  /* Focus visible — WCAG 2.2 AA */
  .cta-wa-flotante:focus-visible {
    outline: 3px solid #25D366;
    outline-offset: 4px;
    border-radius: 50%; /* círculo */
  }

  .cta-wa-flotante--con-texto:focus-visible {
    border-radius: 3rem; /* pill cuando tiene texto */
  }

  .cta-wa-flotante__icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .cta-wa-flotante__texto {
    white-space: nowrap;
  }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .cta-wa-flotante {
      transition: background-color 0.15s ease;
    }
    .cta-wa-flotante:hover {
      transform: none;
    }
  }

  /* Mobile: solo icono en pantallas muy pequeñas */
  @media (max-width: 360px) {
    .cta-wa-flotante--con-texto {
      padding: 0.875rem;
    }
    .cta-wa-flotante__texto {
      display: none;
    }
  }
</style>
