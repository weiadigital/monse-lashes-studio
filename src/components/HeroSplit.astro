---
interface Stat {
  numero: string;
  label: string;
}

interface Props {
  titulo: string;
  subtitulo?: string;
  ctaTexto: string;
  ctaUrl: string;
  imagenSrc: string;
  imagenAlt: string;
  imagenLado?: 'izquierda' | 'derecha';
  badge?: string;
  ctaSecundarioTexto?: string;
  ctaSecundarioUrl?: string;
  /**
   * stats[0] y stats[1] aparecen como tarjetas flotantes sobre la imagen.
   * stats[2]+ aparecen como barra de stats debajo del CTA.
   */
  stats?: Stat[];
}

const {
  titulo,
  subtitulo,
  ctaTexto,
  ctaUrl,
  imagenSrc,
  imagenAlt,
  imagenLado = 'derecha',
  badge,
  ctaSecundarioTexto,
  ctaSecundarioUrl,
  stats = [],
} = Astro.props;

const reverse = imagenLado === 'izquierda';
const card1    = stats[0];
const card2    = stats[1];
const statsBar = stats.slice(2);
---

<section class={`hero-split${reverse ? ' hero-split--reverse' : ''}`}>
  <!-- Columna texto -->
  <div class="hero-split__text">
    <div class="hero-split__atm hero-split__atm--1" aria-hidden="true"></div>
    <div class="hero-split__atm hero-split__atm--2" aria-hidden="true"></div>

    <div class="hero-split__text-inner">
      {badge && <span class="hero-split__badge">{badge}</span>}
      <h1 class="hero-split__title">{titulo}</h1>
      {subtitulo && <p class="hero-split__sub">{subtitulo}</p>}

      <div class="hero-split__actions">
        <a href={ctaUrl} class="hero-split__cta">{ctaTexto}</a>
        {ctaSecundarioTexto && (
          <a href={ctaSecundarioUrl ?? '#contacto'} class="hero-split__cta-ghost">
            {ctaSecundarioTexto}
          </a>
        )}
      </div>

      {statsBar.length > 0 && (
        <div class="hero-split__stats-bar">
          {statsBar.map((s, i) => (
            <>
              <div class="hero-split__stat">
                <span class="hero-split__stat-num">{s.numero}</span>
                <span class="hero-split__stat-label">{s.label}</span>
              </div>
              {i < statsBar.length - 1 && (
                <div class="hero-split__stat-sep" aria-hidden="true"></div>
              )}
            </>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Columna imagen -->
  <div class="hero-split__image-wrap">
    <img
      src={imagenSrc}
      alt={imagenAlt}
      width="720"
      height="900"
      fetchpriority="high"
      decoding="async"
      class="hero-split__img"
    />

    {card1 && (
      <div class="hero-split__card hero-split__card--bottom-left">
        <span class="hero-split__card-num">{card1.numero}</span>
        <span class="hero-split__card-label">{card1.label}</span>
      </div>
    )}

    {card2 && (
      <div class="hero-split__card hero-split__card--top-right">
        <span class="hero-split__card-num">{card2.numero}</span>
        <span class="hero-split__card-label">{card2.label}</span>
      </div>
    )}
  </div>
</section>

<style>
  .hero-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100svh;
    overflow: hidden;
  }

  .hero-split--reverse {
    direction: rtl;
  }
  .hero-split--reverse > * {
    direction: ltr;
  }

  /* ── Columna texto ── */
  .hero-split__text {
    position: relative;
    overflow: hidden;
    background-color: var(--color-surface);
    display: flex;
    align-items: center;
  }

  /* Blur atmosférico decorativo */
  .hero-split__atm {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(90px);
  }
  .hero-split__atm--1 {
    top: -15%;
    right: -20%;
    width: 60%;
    aspect-ratio: 1;
    background: oklch(from var(--color-primary) l c h / 0.13);
  }
  .hero-split__atm--2 {
    bottom: -20%;
    left: -10%;
    width: 45%;
    aspect-ratio: 1;
    background: oklch(from var(--color-primary) l c h / 0.07);
  }

  .hero-split__text-inner {
    position: relative;
    z-index: 1;
    padding: clamp(5.5rem, 9vw, 8rem) clamp(1.5rem, 5vw, 4rem);
    width: 100%;
  }

  /* Badge */
  .hero-split__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3125rem 0.875rem;
    background-color: oklch(from var(--color-primary) l c h / 0.1);
    color: var(--color-primary);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 2rem;
    margin-bottom: 1.5rem;
    border: 1px solid oklch(from var(--color-primary) l c h / 0.2);
    align-self: flex-start;
  }

  /* Heading */
  .hero-split__title {
    font-size: clamp(2rem, 4.5vw, 3.75rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin: 0 0 1.25rem;
    text-wrap: balance;
  }

  .hero-split__sub {
    font-size: clamp(0.9375rem, 1.8vw, 1.125rem);
    line-height: 1.7;
    color: oklch(from var(--color-text) l c h / 0.72);
    margin: 0 0 2.5rem;
    max-width: 44ch;
  }

  /* CTAs */
  .hero-split__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .hero-split__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9375rem 2.25rem;
    background-color: var(--color-cta);
    color: oklch(99% 0.005 230);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 2rem;
    text-decoration: none;
    transition: filter 0.2s, transform 0.15s;
    box-shadow: 0 4px 16px oklch(from var(--color-cta) l c h / 0.3);
  }

  .hero-split__cta:hover {
    filter: brightness(1.08);
    transform: translateY(-2px);
  }

  .hero-split__cta-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.9375rem 2rem;
    border: 2px solid oklch(from var(--color-text) l c h / 0.2);
    color: var(--color-text);
    font-weight: 600;
    font-size: 1rem;
    border-radius: 2rem;
    text-decoration: none;
    transition: border-color 0.2s, background-color 0.2s;
  }

  .hero-split__cta-ghost:hover {
    border-color: oklch(from var(--color-text) l c h / 0.4);
    background-color: oklch(from var(--color-text) l c h / 0.04);
  }

  /* Stats bar */
  .hero-split__stats-bar {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    row-gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid oklch(from var(--color-text) l c h / 0.1);
  }

  .hero-split__stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-inline: 1.25rem;
  }
  .hero-split__stat:first-child { padding-left: 0; }

  .hero-split__stat-num {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 900;
    color: var(--color-text);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .hero-split__stat-label {
    font-size: 0.8125rem;
    color: oklch(from var(--color-text) l c h / 0.6);
    font-weight: 500;
  }

  .hero-split__stat-sep {
    width: 1px;
    height: 2.5rem;
    background-color: oklch(from var(--color-text) l c h / 0.15);
    flex-shrink: 0;
  }

  /* ── Columna imagen ── */
  .hero-split__image-wrap {
    position: relative;
    overflow: hidden;
  }

  .hero-split__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Floating stat cards */
  .hero-split__card {
    position: absolute;
    background-color: oklch(from var(--color-surface) l c h / 0.95);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 1rem;
    padding: 0.9375rem 1.375rem;
    box-shadow: 0 8px 32px oklch(0% 0 0 / 0.22);
    border: 1px solid oklch(99% 0.005 230 / 0.6);
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .hero-split__card--bottom-left {
    bottom: 2.5rem;
    left: -1.25rem;
  }

  .hero-split__card--top-right {
    top: 2.5rem;
    right: -1.25rem;
  }

  .hero-split__card-num {
    font-size: 1.625rem;
    font-weight: 900;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .hero-split__card-label {
    font-size: 0.8125rem;
    color: oklch(from var(--color-text) l c h / 0.7);
    font-weight: 500;
    white-space: nowrap;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .hero-split {
      grid-template-columns: 1fr;
      min-height: auto;
      direction: ltr;
    }

    .hero-split__image-wrap {
      height: clamp(18rem, 65vw, 30rem);
      order: -1;
    }

    .hero-split__card--bottom-left {
      left: 1rem;
      bottom: 1rem;
    }

    .hero-split__card--top-right {
      right: 1rem;
      top: 1rem;
    }

    .hero-split__text-inner {
      padding-top: 3rem;
    }

    .hero-split__actions {
      flex-direction: column;
    }
    .hero-split__cta,
    .hero-split__cta-ghost {
      justify-content: center;
    }
  }
</style>
