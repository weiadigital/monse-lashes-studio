---
/**
 * SocialProofLogos.astro — Logos de clientes, certificaciones o medios
 * Zero JS. WCAG 2.2 AA.
 * Uso: servicios profesionales, inmobiliaria, salud con certificaciones
 */

interface Logo {
  src: string;
  alt: string;
  url?: string;
  width?: number;
  height?: number;
}

interface Props {
  logos: Logo[];
  titulo?: string;
  etiqueta?: string; // "Certificado por", "Clientes que confían en nosotros"
  variante?: 'gris' | 'color';
}

const {
  logos,
  titulo,
  etiqueta = 'Confían en nosotros',
  variante = 'gris',
} = Astro.props;
---

<section class={`logos logos--${variante}`} aria-label={etiqueta}>
  <div class="logos__inner">
    {titulo && (
      <h2 class="logos__titulo">{titulo}</h2>
    )}
    <p class="logos__etiqueta">{etiqueta}</p>

    <ul class="logos__lista" role="list">
      {logos.map((logo) => (
        <li class="logos__item">
          {logo.url ? (
            <a
              href={logo.url}
              target="_blank"
              rel="noopener noreferrer"
              class="logos__link"
              aria-label={logo.alt}
            >
              <img
                src={logo.src}
                alt={logo.alt}
                width={logo.width ?? 140}
                height={logo.height ?? 60}
                loading="lazy"
                decoding="async"
                class="logos__img"
              />
            </a>
          ) : (
            <img
              src={logo.src}
              alt={logo.alt}
              width={logo.width ?? 140}
              height={logo.height ?? 60}
              loading="lazy"
              decoding="async"
              class="logos__img"
            />
          )}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .logos {
    padding: clamp(3rem, 7vw, 5rem) clamp(1.25rem, 5vw, 3rem);
    background-color: var(--color-surface);
  }

  .logos__inner {
    max-width: 72rem;
    margin-inline: auto;
    text-align: center;
  }

  .logos__titulo {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 0.75rem;
  }

  .logos__etiqueta {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: oklch(from var(--color-text) l c h / 0.45);
    margin: 0 0 2.5rem;
  }

  .logos__lista {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 2.5rem 3.5rem;
  }

  .logos__item {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logos__link {
    display: block;
    border-radius: 0.375rem;
    transition: opacity 0.2s;
  }

  .logos__link:hover {
    opacity: 0.75;
  }

  .logos__link:focus-visible {
    outline: 3px solid var(--color-cta);
    outline-offset: 4px;
  }

  /* Variante gris — logos en escala de grises */
  .logos--gris .logos__img {
    filter: grayscale(100%) opacity(0.5);
    transition: filter 0.3s;
    max-height: 3.5rem;
    width: auto;
    object-fit: contain;
  }

  .logos--gris .logos__item:hover .logos__img,
  .logos--gris .logos__link:focus-visible .logos__img {
    filter: grayscale(0%) opacity(1);
  }

  /* Variante color — logos en color completo */
  .logos--color .logos__img {
    max-height: 3.5rem;
    width: auto;
    object-fit: contain;
    filter: opacity(0.85);
    transition: filter 0.2s;
  }

  .logos--color .logos__item:hover .logos__img {
    filter: opacity(1);
  }

  @media (max-width: 480px) {
    .logos__lista {
      gap: 2rem;
    }
  }
</style>
