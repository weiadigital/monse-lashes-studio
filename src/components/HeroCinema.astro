---
interface Stat {
  numero: string;
  label: string;
}

interface Props {
  titulo: string;
  subtitulo?: string;
  ctaTexto: string;
  ctaUrl: string;
  imagenSrc: string;
  imagenAlt: string;
  supratitulo?: string;
  ctaSecundarioTexto?: string;
  ctaSecundarioUrl?: string;
  stats?: Stat[];
  /** telefono se usa como ctaSecundario si no hay ctaSecundarioTexto */
  telefono?: string;
}

const {
  titulo,
  subtitulo,
  ctaTexto,
  ctaUrl,
  imagenSrc,
  imagenAlt,
  supratitulo,
  ctaSecundarioTexto,
  ctaSecundarioUrl,
  stats = [],
  telefono,
} = Astro.props;

const ghost = ctaSecundarioTexto
  ? { texto: ctaSecundarioTexto, url: ctaSecundarioUrl ?? '#contacto' }
  : telefono
    ? { texto: 'Llamar ahora', url: `tel:${telefono.replace(/\D/g, '')}` }
    : null;
---

<section class="hero-cinema" id="main-content">
  <div class="hero-cinema__bg">
    <img
      src={imagenSrc}
      alt={imagenAlt}
      width="1440"
      height="810"
      fetchpriority="high"
      decoding="async"
    />
    <div class="hero-cinema__overlay" aria-hidden="true"></div>
  </div>

  <div class="hero-cinema__content">
    {supratitulo && (
      <span class="hero-cinema__supratitulo">{supratitulo}</span>
    )}
    <h1 class="hero-cinema__title">{titulo}</h1>
    {subtitulo && <p class="hero-cinema__sub">{subtitulo}</p>}

    <div class="hero-cinema__actions">
      <a href={ctaUrl} class="btn-cta">{ctaTexto}</a>
      {ghost && (
        <a href={ghost.url} class="btn-ghost">{ghost.texto}</a>
      )}
    </div>

    {stats.length > 0 && (
      <div class="hero-cinema__stats" role="list">
        {stats.map((s, i) => (
          <>
            <div class="hero-cinema__stat" role="listitem">
              <span class="hero-cinema__stat-num">{s.numero}</span>
              <span class="hero-cinema__stat-label">{s.label}</span>
            </div>
            {i < stats.length - 1 && (
              <div class="hero-cinema__stat-sep" aria-hidden="true"></div>
            )}
          </>
        ))}
      </div>
    )}
  </div>

  <a href="#main-content" class="hero-cinema__scroll" aria-label="Ir al contenido principal">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
      stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 5v14M5 12l7 7 7-7"/>
    </svg>
  </a>
</section>

<style>
  .hero-cinema {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(3.5rem, 9vw, 7rem);
    overflow: hidden;
  }

  .hero-cinema__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-cinema__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .hero-cinema__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      oklch(10% 0.02 270 / 0.97) 0%,
      oklch(10% 0.02 270 / 0.6)  45%,
      oklch(10% 0.02 270 / 0.2)  100%
    );
  }

  .hero-cinema__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 72rem;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 5vw, 3rem);
  }

  /* Supratítulo pill */
  .hero-cinema__supratitulo {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 1rem;
    background-color: oklch(from var(--color-primary) l c h / 0.85);
    color: oklch(99% 0.005 230);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-radius: 2rem;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(4px);
  }

  .hero-cinema__title {
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: oklch(99% 0.005 230);
    margin: 0 0 1rem;
    max-width: 18ch;
    text-wrap: balance;
  }

  .hero-cinema__sub {
    font-size: clamp(1rem, 2.5vw, 1.375rem);
    color: oklch(88% 0.01 230);
    margin: 0 0 2.5rem;
    max-width: 46ch;
    line-height: 1.6;
  }

  .hero-cinema__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.9375rem 2.25rem;
    background-color: var(--color-cta);
    color: oklch(99% 0.005 230);
    font-weight: 700;
    font-size: 1.0625rem;
    border-radius: 2rem;
    text-decoration: none;
    transition: filter 0.2s, transform 0.15s;
    box-shadow: 0 4px 20px oklch(from var(--color-cta) l c h / 0.4);
  }

  .btn-cta:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.9375rem 2.25rem;
    border: 2px solid oklch(99% 0.005 230 / 0.45);
    color: oklch(99% 0.005 230);
    font-weight: 600;
    font-size: 1.0625rem;
    border-radius: 2rem;
    text-decoration: none;
    transition: border-color 0.2s, background-color 0.2s;
  }

  .btn-ghost:hover {
    border-color: oklch(99% 0.005 230 / 0.8);
    background-color: oklch(99% 0.005 230 / 0.1);
  }

  /* Stats bar */
  .hero-cinema__stats {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    row-gap: 1.25rem;
    padding-top: 2rem;
    border-top: 1px solid oklch(99% 0.005 230 / 0.2);
  }

  .hero-cinema__stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-inline: 1.5rem;
  }

  .hero-cinema__stat:first-child {
    padding-left: 0;
  }

  .hero-cinema__stat-num {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 900;
    color: oklch(99% 0.005 230);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .hero-cinema__stat-label {
    font-size: 0.8125rem;
    color: oklch(80% 0.01 230);
    font-weight: 500;
  }

  .hero-cinema__stat-sep {
    width: 1px;
    height: 3rem;
    background-color: oklch(99% 0.005 230 / 0.25);
    flex-shrink: 0;
  }

  /* Scroll indicator */
  .hero-cinema__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: oklch(99% 0.005 230 / 0.55);
    text-decoration: none;
    animation: bounce-down 2s ease-in-out infinite;
    transition: color 0.2s;
  }

  .hero-cinema__scroll:hover {
    color: oklch(99% 0.005 230 / 0.9);
  }

  @keyframes bounce-down {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(8px); }
  }

  @media (max-width: 640px) {
    .hero-cinema__actions {
      flex-direction: column;
      align-items: stretch;
    }
    .btn-cta, .btn-ghost {
      justify-content: center;
    }
    .hero-cinema__stat {
      padding-inline: 1rem;
    }
  }
</style>
