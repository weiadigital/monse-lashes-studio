---
interface Stat {
  numero: string;
  label: string;
}

interface Props {
  titulo: string;
  subtitulo?: string;
  ctaTexto: string;
  ctaUrl: string;
  badge?: string;
  ctaSecundarioTexto?: string;
  ctaSecundarioUrl?: string;
  stats?: Stat[];
}

const {
  titulo,
  subtitulo,
  ctaTexto,
  ctaUrl,
  badge,
  ctaSecundarioTexto,
  ctaSecundarioUrl,
  stats = [],
} = Astro.props;
---

<section class="hero-minimal">
  <div class="hero-minimal__inner">
    {badge && <span class="hero-minimal__badge">{badge}</span>}
    <h1 class="hero-minimal__title">{titulo}</h1>
    {subtitulo && <p class="hero-minimal__sub">{subtitulo}</p>}

    <div class="hero-minimal__actions">
      <a href={ctaUrl} class="hero-minimal__cta">{ctaTexto}</a>
      {ctaSecundarioTexto && (
        <a href={ctaSecundarioUrl ?? '#servicios'} class="hero-minimal__cta-ghost">
          {ctaSecundarioTexto}
        </a>
      )}
    </div>

    {stats.length > 0 && (
      <div class="hero-minimal__stats">
        {stats.map((s, i) => (
          <>
            <div class="hero-minimal__stat">
              <span class="hero-minimal__stat-num">{s.numero}</span>
              <span class="hero-minimal__stat-label">{s.label}</span>
            </div>
            {i < stats.length - 1 && (
              <div class="hero-minimal__stat-sep" aria-hidden="true"></div>
            )}
          </>
        ))}
      </div>
    )}
  </div>

  <div class="hero-minimal__accent hero-minimal__accent--1" aria-hidden="true"></div>
  <div class="hero-minimal__accent hero-minimal__accent--2" aria-hidden="true"></div>
</section>

<style>
  .hero-minimal {
    position: relative;
    min-height: clamp(28rem, 70svh, 52rem);
    display: flex;
    align-items: center;
    background-color: var(--color-surface);
    overflow: hidden;
    /* Espacio para navbar fija */
    padding-top: 5rem;
  }

  .hero-minimal__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 72rem;
    margin-inline: auto;
    padding: clamp(3rem, 8vw, 5rem) clamp(1.25rem, 5vw, 3rem);
  }

  /* Badge */
  .hero-minimal__badge {
    display: inline-flex;
    align-items: center;
    padding: 0.3125rem 1rem;
    background-color: oklch(from var(--color-primary) l c h / 0.12);
    color: var(--color-primary);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 2rem;
    margin-bottom: 1.5rem;
    border: 1px solid oklch(from var(--color-primary) l c h / 0.2);
  }

  /* Heading */
  .hero-minimal__title {
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin: 0 0 1.25rem;
    max-width: 20ch;
    text-wrap: balance;
  }

  .hero-minimal__sub {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: oklch(from var(--color-text) l c h / 0.7);
    line-height: 1.65;
    max-width: 50ch;
    margin: 0 0 2.5rem;
  }

  /* CTAs */
  .hero-minimal__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }

  .hero-minimal__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.9375rem 2.25rem;
    background-color: var(--color-cta);
    color: oklch(99% 0.005 230);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 2rem;
    text-decoration: none;
    transition: filter 0.2s, transform 0.15s;
    box-shadow: 0 4px 16px oklch(from var(--color-cta) l c h / 0.3);
  }

  .hero-minimal__cta:hover {
    filter: brightness(1.08);
    transform: translateY(-2px);
  }

  .hero-minimal__cta-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.9375rem 2rem;
    border: 2px solid oklch(from var(--color-text) l c h / 0.22);
    color: var(--color-text);
    font-weight: 600;
    font-size: 1rem;
    border-radius: 2rem;
    text-decoration: none;
    transition: border-color 0.2s, background-color 0.2s;
  }

  .hero-minimal__cta-ghost:hover {
    border-color: oklch(from var(--color-text) l c h / 0.4);
    background-color: oklch(from var(--color-text) l c h / 0.04);
  }

  /* Stats inline */
  .hero-minimal__stats {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    row-gap: 1rem;
    padding-top: 2rem;
    border-top: 1px solid oklch(from var(--color-text) l c h / 0.1);
  }

  .hero-minimal__stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-inline: 1.25rem;
  }
  .hero-minimal__stat:first-child { padding-left: 0; }

  .hero-minimal__stat-num {
    font-size: clamp(1.375rem, 3vw, 1.875rem);
    font-weight: 900;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .hero-minimal__stat-label {
    font-size: 0.875rem;
    color: oklch(from var(--color-text) l c h / 0.65);
    font-weight: 500;
    line-height: 1.3;
  }

  .hero-minimal__stat-sep {
    width: 1px;
    height: 2rem;
    background-color: oklch(from var(--color-text) l c h / 0.15);
    flex-shrink: 0;
  }

  /* Atmospheric blurs */
  .hero-minimal__accent {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(80px);
  }

  .hero-minimal__accent--1 {
    top: -10%;
    right: -5%;
    width: clamp(18rem, 45vw, 36rem);
    aspect-ratio: 1;
    background: radial-gradient(
      ellipse at center,
      oklch(from var(--color-primary) l c h / 0.18) 0%,
      transparent 70%
    );
  }

  .hero-minimal__accent--2 {
    bottom: -20%;
    left: -5%;
    width: clamp(14rem, 35vw, 28rem);
    aspect-ratio: 1;
    background: radial-gradient(
      ellipse at center,
      oklch(from var(--color-primary) l c h / 0.08) 0%,
      transparent 70%
    );
  }

  @media (max-width: 640px) {
    .hero-minimal__actions {
      flex-direction: column;
    }
    .hero-minimal__cta,
    .hero-minimal__cta-ghost {
      justify-content: center;
    }
  }
</style>
