---
/**
 * Gallery.astro — Galería de imágenes en grid con lightbox CSS nativo
 * Usa popover API (baseline 2024) con fallback graceful
 * Zero JS. WCAG 2.2 AA. Lazy loading automático.
 * Uso: Nail salon, barbería, belleza, comida
 */

interface Imagen {
  src: string;
  alt: string;
  width?: number;
  height?: number;
}

interface Props {
  imagenes: Imagen[];
  titulo?: string;
  columnas?: 2 | 3 | 4;
  mostrarTitulo?: boolean;
}

const {
  imagenes,
  titulo = 'Galería',
  columnas = 3,
  mostrarTitulo = true,
} = Astro.props;
---

<section class="gallery" aria-labelledby="gallery-heading">
  <div class="gallery__inner">
    {mostrarTitulo && (
      <h2 class="gallery__heading" id="gallery-heading">{titulo}</h2>
    )}

    <ul
      class="gallery__grid"
      role="list"
      style={`--cols: ${columnas}`}
    >
      {imagenes.map((img, i) => {
        const popoverId = `gallery-pop-${i}`;
        return (
          <li class="gallery__item">
            <button
              class="gallery__trigger"
              popovertarget={popoverId}
              aria-label={`Ver imagen: ${img.alt}`}
            >
              <img
                src={img.src}
                alt={img.alt}
                width={img.width ?? 600}
                height={img.height ?? 450}
                loading="lazy"
                decoding="async"
                class="gallery__thumb"
              />
              <span class="gallery__zoom-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="11" cy="11" r="8"/>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                  <line x1="11" y1="8" x2="11" y2="14"/>
                  <line x1="8" y1="11" x2="14" y2="11"/>
                </svg>
              </span>
            </button>

            <div
              id={popoverId}
              popover="auto"
              class="gallery__lightbox"
              aria-label={img.alt}
            >
              <button
                class="gallery__close"
                popovertarget={popoverId}
                popovertargetaction="hide"
                aria-label="Cerrar imagen"
              >
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <line x1="18" y1="6" x2="6" y2="18"/>
                  <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
              </button>
              <img
                src={img.src}
                alt={img.alt}
                class="gallery__lightbox-img"
                width={img.width ?? 1200}
                height={img.height ?? 900}
                loading="lazy"
                decoding="async"
              />
              <p class="gallery__lightbox-caption">{img.alt}</p>
            </div>
          </li>
        );
      })}
    </ul>
  </div>
</section>

<style>
  .gallery {
    padding: clamp(4rem, 10vw, 7rem) clamp(1.25rem, 5vw, 3rem);
    background-color: oklch(from var(--color-surface) calc(l - 0.025) c h);
  }

  .gallery__inner {
    max-width: 72rem;
    margin-inline: auto;
  }

  .gallery__heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 2.5rem;
    text-align: center;
  }

  .gallery__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: 0.75rem;
  }

  /* Primer item más grande — asimetría visual */
  .gallery__item:first-child {
    grid-column: span 2;
    grid-row: span 2;
  }

  .gallery__trigger {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    border: none;
    padding: 0;
    cursor: pointer;
    background: none;
    border-radius: 0.75rem;
  }

  .gallery__item:first-child .gallery__trigger {
    aspect-ratio: 1; /* se estira por span */
    height: 100%;
  }

  .gallery__thumb {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: block;
  }

  .gallery__trigger:hover .gallery__thumb {
    transform: scale(1.05);
  }

  .gallery__zoom-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: oklch(0% 0 0 / 0);
    color: white;
    opacity: 0;
    transition: background-color 0.3s, opacity 0.3s;
    border-radius: 0.75rem;
  }

  .gallery__trigger:hover .gallery__zoom-icon,
  .gallery__trigger:focus-visible .gallery__zoom-icon {
    background-color: oklch(0% 0 0 / 0.4);
    opacity: 1;
  }

  .gallery__trigger:focus-visible {
    outline: 3px solid var(--color-cta);
    outline-offset: 3px;
    border-radius: 0.75rem;
  }

  /* Lightbox — Popover API */
  .gallery__lightbox {
    border: none;
    background: oklch(5% 0.01 270 / 0.96);
    padding: 0;
    max-width: 100vw;
    max-height: 100dvh;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    backdrop-filter: blur(8px);
  }

  .gallery__lightbox:popover-open {
    display: flex;
  }

  /* Overlay oscuro */
  .gallery__lightbox::backdrop {
    background: oklch(0% 0 0 / 0.85);
  }

  .gallery__close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 2.75rem;
    height: 2.75rem;
    border: 2px solid oklch(100% 0 0 / 0.3);
    border-radius: 50%;
    background: oklch(100% 0 0 / 0.1);
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.2s, border-color 0.2s;
  }

  .gallery__close:hover {
    background: oklch(100% 0 0 / 0.2);
    border-color: oklch(100% 0 0 / 0.6);
  }

  .gallery__close:focus-visible {
    outline: 3px solid var(--color-cta);
    outline-offset: 3px;
  }

  .gallery__lightbox-img {
    max-width: min(90vw, 1000px);
    max-height: 80dvh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 0.5rem;
    box-shadow: 0 24px 80px oklch(0% 0 0 / 0.5);
  }

  .gallery__lightbox-caption {
    font-size: 0.9375rem;
    color: oklch(80% 0.01 230);
    text-align: center;
    max-width: 50ch;
    margin: 0;
    padding: 0 1.5rem;
  }

  /* Fallback — si el navegador no soporta popover */
  @supports not selector(:popover-open) {
    .gallery__lightbox {
      display: none;
    }
    .gallery__trigger {
      cursor: default;
    }
    .gallery__zoom-icon {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .gallery__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .gallery__item:first-child {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
</style>
