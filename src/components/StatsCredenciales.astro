---
/**
 * StatsCredenciales.astro — Fila de números de credibilidad
 * Fondo: --color-primary. Grid de 2-4 stats.
 * Zero JS. WCAG 2.2 AA.
 * Uso: T2-SplitProfesional. Salud, legal, servicios profesionales.
 *
 * INSTRUCCIÓN PARA MIXTLI:
 * Todos los números deben ser reales y verificables.
 * NUNCA inventar: años, pacientes, casos, certificaciones.
 * Si el cliente no tiene datos verificables → omitir este componente.
 */

interface Stat {
  numero: string;   // ej. "15", "3,200", "4.9"
  label: string;    // ej. "años de experiencia", "pacientes atendidos"
  sufijo?: string;  // ej. "★" para calificación, "+" para aproximados
}

interface Props {
  stats: Stat[];
  ariaNombre?: string;
}

const {
  stats,
  ariaNombre = 'Credenciales y experiencia',
} = Astro.props;
---

<section class="stats-cred" aria-label={ariaNombre}>
  <div class="stats-cred__inner" style={`--cols: ${Math.min(stats.length, 4)}`}>
    {stats.map((s) => (
      <div class="stats-cred__item">
        <p class="stats-cred__num" aria-hidden="true">
          {s.numero}{s.sufijo && <span class="stats-cred__sufijo-inline">{s.sufijo}</span>}
        </p>
        <p class="stats-cred__label">{s.label}</p>
      </div>
    ))}
  </div>
</section>

<style>
  .stats-cred {
    padding: clamp(3.5rem, 8vw, 5.5rem) clamp(1.25rem, 5vw, 3rem);
    background-color: var(--color-primary);
  }

  .stats-cred__inner {
    max-width: 64rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stats-cred__num {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: oklch(12% 0.02 270);
    line-height: 1;
    margin: 0 0 0.375rem;
    font-family: var(--font-heading, inherit);
  }

  .stats-cred__sufijo-inline {
    font-size: 0.55em;
    vertical-align: super;
  }

  .stats-cred__label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: oklch(20% 0.03 270 / 0.75);
    margin: 0;
    line-height: 1.4;
  }

  @media (max-width: 600px) {
    .stats-cred__inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 380px) {
    .stats-cred__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
