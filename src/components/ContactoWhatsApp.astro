---
interface Props {
  titulo?: string;
  telefono: string;
  mensaje?: string;
  direccion: string;
  horario?: string;
  googleMapsEmbed?: string;
}

const {
  titulo = '¿Cómo llegar?',
  telefono,
  mensaje = 'Hola, vi tu página y quiero más información',
  direccion,
  horario,
  googleMapsEmbed,
} = Astro.props;

const phoneClean = telefono.replace(/\D/g, '');
const waUrl = `https://api.whatsapp.com/send?phone=521${phoneClean}&text=${encodeURIComponent(mensaje + ' (ref:website)')}`;
const telUrl = `tel:+52${phoneClean}`;
---

<section class="contacto-wa">
  <div class="contacto-wa__inner">
    <div class="contacto-wa__info">
      <h2 class="contacto-wa__heading">{titulo}</h2>

      <address class="contacto-wa__details">
        <div class="contacto-wa__item">
          <svg class="contacto-wa__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span>{direccion}</span>
        </div>

        {horario && (
          <div class="contacto-wa__item">
            <svg class="contacto-wa__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>{horario}</span>
          </div>
        )}

        <div class="contacto-wa__item">
          <svg class="contacto-wa__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012.18 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.72 6.72l1.28-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
          </svg>
          <a href={telUrl} class="contacto-wa__tel">{telefono}</a>
        </div>
      </address>

      <div class="contacto-wa__actions">
        <a
          href={waUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-whatsapp"
          aria-label="Escribir por WhatsApp"
        >
          {/* SVG oficial WhatsApp — Brand Kit de Meta/WhatsApp */}
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Escribir por WhatsApp
        </a>
      </div>
    </div>

    {googleMapsEmbed && (
      <div class="contacto-wa__map">
        <iframe
          src={googleMapsEmbed}
          width="600"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`Mapa de ubicación de ${direccion}`}
        ></iframe>
      </div>
    )}
  </div>
</section>

<style>
  .contacto-wa {
    padding: clamp(4rem, 10vw, 7rem) clamp(1.25rem, 5vw, 3rem);
    background-color: oklch(from var(--color-surface) calc(l - 0.025) c h);
  }

  .contacto-wa__inner {
    max-width: 72rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .contacto-wa__heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 2rem;
  }

  .contacto-wa__details {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .contacto-wa__item {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    font-size: 0.9375rem;
    color: oklch(from var(--color-text) l c h / 0.8);
    line-height: 1.6;
  }

  .contacto-wa__icon {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 0.125rem;
  }

  .contacto-wa__tel {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 600;
  }

  .contacto-wa__tel:hover {
    color: var(--color-cta);
  }

  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.75rem;
    background-color: #25D366;
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.15s;
  }

  .btn-whatsapp:hover {
    opacity: 0.9;
    transform: translateY(-2px);
  }

  .contacto-wa__map {
    border-radius: 1rem;
    overflow: hidden;
    aspect-ratio: 4/3;
    box-shadow: 0 8px 32px oklch(0% 0 0 / 0.12);
  }

  .contacto-wa__map iframe {
    width: 100%;
    height: 100%;
    display: block;
  }

  @media (max-width: 768px) {
    .contacto-wa__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .contacto-wa__map {
      order: -1;
      aspect-ratio: 16/9;
    }
  }
</style>
